DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 1

0000                         1  * BOOT ROM for C-FLEA on Primer 25K
0000                         2  * Parses basic S records (S1 and S9) as well as Gxxxx command to run programs
0000                         3  
0000                         4  * we have 2KB of ROM starting at F000
F000                         5     ORG $F000
F000                         6  
F000                         7  * some variables to keep state, let's hide them at the end of video mem
FFFF                         8  temp EQU $FFFF    * temp variables
FFFE                         9  temp2 EQU $FFFE
FFFD                        10  temp3 EQU $FFFD
FFFC                        11  temp4 EQU $FFFC   * n
FFFA                        12  addr EQU $FFFA    * we can 16-bit load the addr from here
FFFB                        13  addrhi EQU $FFFB  * and write to the top half here
F900                        14  stack EQU $F900   * stack inside the video so we have something to see
F000                        15  
F000  00 00 F9              16     LD #stack
F003  DE                    17     TAS          * SP = stack (F900)
F004                        18  top
F004  EB 00                 19     IN $00       * read from UART
F006  D4 FC                 20     SJZ top      * loop while no char
F008  EA 00                 21     OUT $00
F00A  A9 FF FF              22     STB temp
F00D  88 53                 23     CMPB #'S'    * compare to S
F00F  D5 09                 24     SJNZ is_S    * it's an 'S' so jump to that handler
F011  09 FF FF              25     LDB temp
F014  88 47                 26     CMPB #'G'
F016  D5 39                 27     SJNZ is_G    * it's an 'G' jump there
F018  D3 EA                 28     SJMP top     * ignore and jump to top
F01A                        29  
F01A                        30  * S records we need 
F01A                        31  * 1. Read command '1' or '9'
F01A                        32  * 2. Read 1 hex byte, n =  # of data + 3
F01A                        33  * 3. Read 2 hex bytes (addr)
F01A                        34  * 4. Read n - 3 hex bytes (data)
F01A                        35  * 5. Read 1 hex byte (checksum)
F01A                        36  is_S
F01A  EB 00                 37     IN $00
F01C  D4 FC                 38     SJZ is_S       * wait for a char (the command)
F01E  EA 00                 39     OUT $00
F020  D8 65 F0              40     CALL read_hex  * read the # of bytes 'n'
F023  28 03                 41     SUBB #3		  * sub addr/checksum
F025  A9 FC FF              42     STB temp4      * temp4 == n
F028  D8 65 F0              43     CALL read_hex  * read addrhi
F02B  A9 FB FF              44     STB addrhi
F02E  D8 65 F0              45     CALL read_hex  * read bottom
F031  A9 FA FF              46     STB addr
F034  91 FA FF              47     LDI addr       * INDEX = address to store to
F037                        48  is_S_loop
F037  08 73                 49     LDB #'s'
F039  EA 00                 50     OUT $00
F03B  D8 65 F0              51     CALL read_hex
F03E  AA                    52     STB I		  * store via index
F03F  E7                    53     TIA			  * increment index
F040  E4                    54     INC
F041  E6                    55     TAI
F042  09 FC FF              56     LDB temp4      * load n
F045  E5                    57     DEC
F046  A9 FC FF              58     STB temp4
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 2

F049  D5 EC                 59     SJNZ is_S_loop
F04B  D8 65 F0              60     CALL read_hex  * skip checksum
F04E  D0 04 F0              61     JMP top
F051                        62     
F051                        63  is_G
F051  08 67                 64     LDB #'g'
F053  EA 00                 65     OUT $00
F055  D8 65 F0              66     CALL read_hex  * read address
F058  A9 FB FF              67     STB addrhi
F05B  D8 65 F0              68     CALL read_hex
F05E  A9 FA FF              69     STB addr
F061  01 FA FF              70     LD addr        * jump to address
F064  D6                    71     IJMP
F065                        72  
F065                        73  * read hex byte into ACC
F065                        74  read_hex EQU *
F065  08 72                 75     LDB #'r'
F067  EA 00                 76     OUT $00
F069  E0                    77     CLR
F06A  A9 FF FF              78     STB temp         * zero the temp byte
F06D  08 02                 79     LDB #2
F06F  A9 FE FF              80     STB temp2        * zero nibble count
F072                        81  read_hex_top
F072  09 FF FF              82     LDB temp         * shift temp up 4 bits for next nibble
F075  C0 04                 83     SHL #4
F077  A9 FF FF              84     STB temp
F07A                        85  read_hex_loop
F07A  EB 00                 86     IN $00
F07C  D4 FC                 87     SJZ read_hex_loop * read from uart
F07E  EA 00                 88     OUT $00          * echo back
F080  A9 FD FF              89     STB temp3		* save the char being read
F083  88 39                 90     CMPB #'9'        * assume it's 0-9A-F
F085  CE                    91     UGT              * check for >'9'
F086  D5 16                 92     SJNZ read_hex_af
F088  09 FD FF              93     LDB temp3        * readload byte
F08B  28 30                 94     SUBB #'0'		* it's 0-9
F08D                        95  read_hex_store_nibble
F08D  69 FF FF              96     ORB temp			* or with accumulated data
F090  A9 FF FF              97     STB temp         * store back
F093  09 FE FF              98     LDB temp2
F096  E5                    99     DEC
F097  A9 FE FF             100     STB temp2
F09A  D5 D6                101     SJNZ read_hex_top
F09C  D3 09                102     SJMP read_hex_end
F09E                       103  read_hex_af
F09E  09 FD FF             104     LDB temp3        * reload byte
F0A1  28 41                105     SUBB #'A'        * subtract 'A'
F0A3  18 0A                106     ADDB #10         * then normalize to 10..15
F0A5  D3 E6                107     SJMP read_hex_store_nibble
F0A7                       108  read_hex_end
F0A7  09 FF FF             109     LDB temp         * we're done
F0AA  D9                   110     RET
F0AB                       111  

DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 1

0000                         1  * BOOT ROM for C-FLEA on Primer 25K
0000                         2  * Parses basic S records (S1 and S9) as well as Gxxxx command to run programs
0000                         3  
0000                         4  * we have 2KB of ROM starting at F000
F000                         5     ORG $F000
F000                         6  
F000                         7  * some variables to keep state, let's hide them at the end of video mem
FFFF                         8  temp EQU $FFFF    * temp variables
FFFE                         9  temp2 EQU $FFFE
FFFD                        10  temp3 EQU $FFFD
FFFC                        11  temp4 EQU $FFFC   * n
FFFA                        12  addr EQU $FFFA    * we can 16-bit load the addr from here
FFFB                        13  addrhi EQU $FFFB  * and write to the top half here
F000                        14  *stack EQU $F900   * stack inside the video so we have something to see
8000                        15  stack EQU $8000 * stack inside main mem for testing...
F000                        16  
F000  00 00 80              17     LD #stack
F003  DE                    18     TAS          * SP = stack (F900)
F004  99 4D F1              19     LEAI ?WELCOMSTR
F007  D8 C2 F0              20     CALL putstr
F00A                        21  top
F00A  EB 00                 22     IN $00       * read from UART
F00C  D4 FC                 23     SJZ top      * loop while no char
F00E  EA 00                 24     OUT $00
F010  A9 FF FF              25     STB temp
F013  88 53                 26     CMPB #'S'    * compare to S
F015  D5 10                 27     SJNZ is_S    * it's an 'S' so jump to that handler
F017  09 FF FF              28     LDB temp
F01A  88 47                 29     CMPB #'G'
F01C  D5 3D                 30     SJNZ is_G    * it's an 'G' jump there
F01E  09 FF FF              31     LDB temp
F021  88 44                 32     CMPB #'D'
F023  D5 46                 33     SJNZ is_D
F025  D3 E3                 34     SJMP top     * ignore and jump to top
F027                        35  
F027                        36  * S records we need 
F027                        37  * 1. Read command '1' or '9'
F027                        38  * 2. Read 1 hex byte, n =  # of data + 3
F027                        39  * 3. Read 2 hex bytes (addr)
F027                        40  * 4. Read n - 3 hex bytes (data)
F027                        41  * 5. Read 1 hex byte (checksum)
F027                        42  is_S
F027  EB 00                 43     IN $00
F029  D4 FC                 44     SJZ is_S       * wait for a char (the command)
F02B  EA 00                 45     OUT $00
F02D  D8 80 F0              46     CALL read_hex  * read the # of bytes 'n'
F030  28 03                 47     SUBB #3		  * sub addr/checksum
F032  D4 D6                 48     SJZ top		  * no bytes to store so just exit out
F034  A9 FC FF              49     STB temp4      * temp4 == n
F037  D8 80 F0              50     CALL read_hex  * read addrhi
F03A  A9 FB FF              51     STB addrhi
F03D  D8 80 F0              52     CALL read_hex  * read bottom
F040  A9 FA FF              53     STB addr
F043  91 FA FF              54     LDI addr       * INDEX = address to store to
F046                        55  is_S_loop
F046  D8 80 F0              56     CALL read_hex
F049  AA                    57     STB I		  * store via index
F04A  9B 01                 58     LEAI 1,I		  * increment iindex
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 2

F04C  09 FC FF              59     LDB temp4      * load n
F04F  E5                    60     DEC
F050  A9 FC FF              61     STB temp4
F053  D5 F1                 62     SJNZ is_S_loop
F055  D8 80 F0              63     CALL read_hex  * skip checksum
F058  D0 0A F0              64     JMP top
F05B                        65     
F05B                        66  is_G
F05B  D8 80 F0              67     CALL read_hex  * read address
F05E  A9 FB FF              68     STB addrhi
F061  D8 80 F0              69     CALL read_hex
F064  A9 FA FF              70     STB addr
F067  01 FA FF              71     LD addr        * jump to address
F06A  D6                    72     IJMP
F06B                        73  
F06B                        74  is_D
F06B  D8 80 F0              75     CALL read_hex
F06E  A9 FB FF              76     STB addrhi
F071  D8 80 F0              77     CALL read_hex
F074  A9 FA FF              78     STB addr
F077  01 FA FF              79     LD addr
F07A  D8 D8 F0              80     CALL puthexline
F07D  D0 0A F0              81     JMP top
F080                        82     
F080                        83  * read hex byte into ACC
F080                        84  read_hex
F080  E0                    85     CLR
F081  A9 FF FF              86     STB temp         * zero the temp byte
F084  08 02                 87     LDB #2
F086  A9 FE FF              88     STB temp2        * zero nibble count
F089                        89  read_hex_top
F089  09 FF FF              90     LDB temp         * shift temp up 4 bits for next nibble
F08C  C0 04                 91     SHL #4
F08E  A9 FF FF              92     STB temp
F091                        93  read_hex_loop
F091  EB 00                 94     IN $00
F093  D4 FC                 95     SJZ read_hex_loop * read from uart
F095  EA 00                 96     OUT $00          * echo back
F097  A9 FD FF              97     STB temp3		* save the char being read
F09A  88 39                 98     CMPB #'9'        * assume it's 0-9A-F
F09C  CE                    99     UGT              * check for >'9'
F09D  D5 16                100     SJNZ read_hex_af
F09F  09 FD FF             101     LDB temp3        * readload byte
F0A2  28 30                102     SUBB #'0'		* it's 0-9
F0A4                       103  read_hex_store_nibble
F0A4  69 FF FF             104     ORB temp			* or with accumulated data
F0A7  A9 FF FF             105     STB temp         * store back
F0AA  09 FE FF             106     LDB temp2
F0AD  E5                   107     DEC
F0AE  A9 FE FF             108     STB temp2
F0B1  D5 D6                109     SJNZ read_hex_top
F0B3  D3 09                110     SJMP read_hex_end
F0B5                       111  read_hex_af
F0B5  09 FD FF             112     LDB temp3        * reload byte
F0B8  28 41                113     SUBB #'A'        * subtract 'A'
F0BA  18 0A                114     ADDB #10         * then normalize to 10..15
F0BC  D3 E6                115     SJMP read_hex_store_nibble
F0BE                       116  read_hex_end
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 3

F0BE  09 FF FF             117     LDB temp         * we're done
F0C1  D9                   118     RET
F0C2                       119  
F0C2                       120  * putstr in INDEX
F0C2                       121  putstr
F0C2  DC                   122  	PUSHA
F0C3  DD                   123  	PUSHI
F0C4                       124  putstrtop
F0C4  0A                   125  	LDB I
F0C5  D4 06                126  	SJZ putstr_end
F0C7  EA 00                127  	OUT $00
F0C9  9B 01                128      LEAI 1,I		  * increment iindex
F0CB  D3 F7                129  	SJMP putstrtop
F0CD                       130  putstr_end
F0CD  95                   131  	LDI S+
F0CE  08 0A                132  	LDB #10
F0D0  EA 00                133  	OUT $00
F0D2  08 0D                134  	LDB #13
F0D4  EA 00                135  	OUT $00
F0D6  05                   136  	LD S+
F0D7  D9                   137  	RET
F0D8                       138  
F0D8                       139  * display 16 bytes at ACC
F0D8                       140  puthexline
F0D8  DD                   141  	PUSHI
F0D9  DC                   142  	PUSHA				* 2,S == address
F0DA  00 10 00             143  	LD #16
F0DD  DC                   144  	PUSHA				* 0,S == number of bytes to print
F0DE                       145  * display newline
F0DE  08 0A                146      LDB #10
F0E0  EA 00                147      OUT $00
F0E2  08 0D                148      LDB #13
F0E4  EA 00                149      OUT $00
F0E6                       150  * display address and space
F0E6  04 02                151  	LD 2,S
F0E8  B8 08                152  	SHR #8
F0EA  D8 1C F1             153      CALL puthex
F0ED  04 02                154  	LD 2,S
F0EF  D8 1C F1             155      CALL puthex
F0F2  08 20                156      LDB #' '
F0F4  EA 00                157      OUT $00
F0F6                       158  * display 16 bytes
F0F6  94 02                159  	LDI 2,S				* address
F0F8                       160  puthexline_top
F0F8  0A                   161  	LDB I				* read byte
F0F9  D8 1C F1             162  	CALL puthex
F0FC  08 20                163  	LDB #' '
F0FE  EA 00                164  	OUT $00
F100  04 02                165  	LD 2,S
F102  E4                   166  	INC
F103  A4 02                167  	ST 2,S
F105  9B 01                168  	LEAI 1,I            * advance index
F107  04 00                169  	LD 0,S
F109  E5                   170  	DEC
F10A  A4 00                171  	ST 0,S
F10C  D2 F8 F0             172  	JNZ puthexline_top
F10F  08 0A                173      LDB #10				* print newline/cr
F111  EA 00                174      OUT $00
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 4

F113  08 0D                175      LDB #13
F115  EA 00                176      OUT $00
F117  DB 02                177  	FREE 2
F119  05                   178  	LD S+
F11A  95                   179  	LDI S+
F11B  D9                   180  	RET
F11C                       181  	
F11C                       182  * put hex from ACC
F11C                       183  puthex
F11C  DD                   184  	PUSHI
F11D  DC                   185  	PUSHA				* save what we are printing 2,S
F11E  00 02 00             186  	LD #2
F121  DC                   187  	PUSHA				* 0,S == # of digits to print
F122                       188  puthex_ch
F122  04 02                189  	LD 2,S
F124  B8 04                190  	SHR #4				* grab only 4 bits
F126  50 0F 00             191  	AND #$F
F129  E6                   192  	TAI					* save it
F12A  88 09                193  	CMPB #9             * compare to 9
F12C  CE                   194  	UGT                 * greater than?
F12D  D5 05                195  	SJNZ puthex_af
F12F  E7                   196  	TIA                 * restore masked copy
F130  18 30                197  	ADDB #'0'           * it was 0-9 so map to '0'-'9'
F132  D3 05                198  	SJMP puthex_bot
F134                       199  puthex_af
F134  E7                   200      TIA
F135  28 0A                201      SUBB #10
F137  18 41                202      ADDB #'A'           * restore and normalize to 'A'-'F'
F139                       203  puthex_bot
F139  EA 00                204      out $00
F13B  04 02                205      LD 2,S
F13D  C0 04                206      SHL #4
F13F  A4 02                207      ST 2,S              * shift right 4 bits
F141  04 00                208      LD 0,S
F143  E5                   209      DEC
F144  A4 00                210      ST 0,S
F146  D5 DA                211      SJNZ puthex_ch
F148  DB 02                212      FREE 2
F14A  05                   213      LD S+
F14B  95                   214      LDI S+
F14C  D9                   215      RET
F14D  43 2D 46 4C 45 41 +  216  ?WELCOMSTR STR "C-FLEA Primer25K monitor -- Tom St Denis"

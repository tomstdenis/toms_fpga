DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 1

0000                         1  * BOOT ROM for C-FLEA on Primer 25K
0000                         2  * Parses basic S records (S1 and S9) as well as Gxxxx command to run programs
0000                         3  
0000                         4  * we have 2KB of ROM starting at F000
F000                         5     ORG $F000
F000                         6  
F000                         7  * some variables to keep state, let's hide them at the end of video mem
FFFF                         8  temp EQU $FFFF    * temp variables
FFFE                         9  temp2 EQU $FFFE
FFFD                        10  temp3 EQU $FFFD
FFFC                        11  temp4 EQU $FFFC   * n
FFFA                        12  addr EQU $FFFA    * we can 16-bit load the addr from here
FFFB                        13  addrhi EQU $FFFB  * and write to the top half here
F000                        14  *stack EQU $F900   * stack inside the video so we have something to see
8000                        15  stack EQU $8000 * stack inside main mem for testing...
F000                        16  
F000  00 00 80              17     LD #stack
F003  DE                    18     TAS          * SP = stack (F900)
F004  99 BC F0              19     LEAI ?STR
F007  D8 B2 F0              20     CALL putstr
F00A                        21  top
F00A  EB 00                 22     IN $00       * read from UART
F00C  D4 FC                 23     SJZ top      * loop while no char
F00E  EA 00                 24     OUT $00
F010  A9 FF FF              25     STB temp
F013  88 53                 26     CMPB #'S'    * compare to S
F015  D5 09                 27     SJNZ is_S    * it's an 'S' so jump to that handler
F017  09 FF FF              28     LDB temp
F01A  88 47                 29     CMPB #'G'
F01C  D5 3A                 30     SJNZ is_G    * it's an 'G' jump there
F01E  D3 EA                 31     SJMP top     * ignore and jump to top
F020                        32  
F020                        33  * S records we need 
F020                        34  * 1. Read command '1' or '9'
F020                        35  * 2. Read 1 hex byte, n =  # of data + 3
F020                        36  * 3. Read 2 hex bytes (addr)
F020                        37  * 4. Read n - 3 hex bytes (data)
F020                        38  * 5. Read 1 hex byte (checksum)
F020                        39  is_S
F020  EB 00                 40     IN $00
F022  D4 FC                 41     SJZ is_S       * wait for a char (the command)
F024  EA 00                 42     OUT $00
F026  D8 6C F0              43     CALL read_hex  * read the # of bytes 'n'
F029  28 03                 44     SUBB #3		  * sub addr/checksum
F02B  D4 DD                 45     SJZ top		  * no bytes to store so just exit out
F02D  A9 FC FF              46     STB temp4      * temp4 == n
F030  D8 6C F0              47     CALL read_hex  * read addrhi
F033  A9 FB FF              48     STB addrhi
F036  D8 6C F0              49     CALL read_hex  * read bottom
F039  A9 FA FF              50     STB addr
F03C  91 FA FF              51     LDI addr       * INDEX = address to store to
F03F                        52  is_S_loop
F03F  08 73                 53     LDB #'s'
F041  EA 00                 54     OUT $00
F043  D8 6C F0              55     CALL read_hex
F046  AA                    56     STB I		  * store via index
F047  9B 01                 57     LEAI 1,I		  * increment iindex
F049  09 FC FF              58     LDB temp4      * load n
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 2

F04C  E5                    59     DEC
F04D  A9 FC FF              60     STB temp4
F050  D5 ED                 61     SJNZ is_S_loop
F052  D8 6C F0              62     CALL read_hex  * skip checksum
F055  D0 0A F0              63     JMP top
F058                        64     
F058                        65  is_G
F058  08 67                 66     LDB #'g'
F05A  EA 00                 67     OUT $00
F05C  D8 6C F0              68     CALL read_hex  * read address
F05F  A9 FB FF              69     STB addrhi
F062  D8 6C F0              70     CALL read_hex
F065  A9 FA FF              71     STB addr
F068  01 FA FF              72     LD addr        * jump to address
F06B  D6                    73     IJMP
F06C                        74     
F06C                        75  * read hex byte into ACC
F06C                        76  read_hex
F06C  08 72                 77     LDB #'r'
F06E  EA 00                 78     OUT $00
F070  E0                    79     CLR
F071  A9 FF FF              80     STB temp         * zero the temp byte
F074  08 02                 81     LDB #2
F076  A9 FE FF              82     STB temp2        * zero nibble count
F079                        83  read_hex_top
F079  09 FF FF              84     LDB temp         * shift temp up 4 bits for next nibble
F07C  C0 04                 85     SHL #4
F07E  A9 FF FF              86     STB temp
F081                        87  read_hex_loop
F081  EB 00                 88     IN $00
F083  D4 FC                 89     SJZ read_hex_loop * read from uart
F085  EA 00                 90     OUT $00          * echo back
F087  A9 FD FF              91     STB temp3		* save the char being read
F08A  88 39                 92     CMPB #'9'        * assume it's 0-9A-F
F08C  CE                    93     UGT              * check for >'9'
F08D  D5 16                 94     SJNZ read_hex_af
F08F  09 FD FF              95     LDB temp3        * readload byte
F092  28 30                 96     SUBB #'0'		* it's 0-9
F094                        97  read_hex_store_nibble
F094  69 FF FF              98     ORB temp			* or with accumulated data
F097  A9 FF FF              99     STB temp         * store back
F09A  09 FE FF             100     LDB temp2
F09D  E5                   101     DEC
F09E  A9 FE FF             102     STB temp2
F0A1  D5 D6                103     SJNZ read_hex_top
F0A3  D3 09                104     SJMP read_hex_end
F0A5                       105  read_hex_af
F0A5  09 FD FF             106     LDB temp3        * reload byte
F0A8  28 41                107     SUBB #'A'        * subtract 'A'
F0AA  18 0A                108     ADDB #10         * then normalize to 10..15
F0AC  D3 E6                109     SJMP read_hex_store_nibble
F0AE                       110  read_hex_end
F0AE  09 FF FF             111     LDB temp         * we're done
F0B1  D9                   112     RET
F0B2                       113  
F0B2                       114  * putstr in INDEX
F0B2                       115  putstr
F0B2  0A                   116  	LDB I
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 3

F0B3  D4 06                117  	SJZ putstr_end
F0B5  EA 00                118  	OUT $00
F0B7  9B 01                119      LEAI 1,I		  * increment iindex
F0B9  D3 F7                120  	SJMP putstr
F0BB                       121  putstr_end
F0BB  D9                   122  	RET
F0BC                       123  
F0BC  48 65 6C 6C 6F 20 +  124  ?STR FCB 72,101,108,108,111,32,87,111,114,108,100,10,13,0

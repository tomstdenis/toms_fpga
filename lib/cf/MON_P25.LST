DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 1

0000                         1  * BOOT ROM for C-FLEA on Primer 25K
0000                         2  * Parses basic S records (S1 and S9) as well as Gxxxx command to run programs
0000                         3  
0000                         4  * we have 2KB of ROM starting at F000
F000                         5     ORG $F000
F000                         6  
F000                         7  * some variables to keep state, let's hide them at the end of video mem
FFFF                         8  temp EQU $FFFF    * temp variables
FFFE                         9  temp2 EQU $FFFE
FFFD                        10  temp3 EQU $FFFD
FFFC                        11  temp4 EQU $FFFC   * n
FFFA                        12  addr EQU $FFFA    * we can 16-bit load the addr from here
FFFB                        13  addrhi EQU $FFFB  * and write to the top half here
F900                        14  stack EQU $F900   * stack inside the video so we have something to see
F000                        15  
F000  00 00 F9              16     LD #stack
F003  DE                    17     TAS          * SP = stack (F900)
F004  99 90 F1              18     LEAI ?WELCOMSTR
F007  D8 E4 F0              19     CALL putstr
F00A                        20  top
F00A  EB 00                 21     IN $00       	* read from UART
F00C  E4                    22     INC
F00D  D4 FB                 23     SJZ top     * loop while no char
F00F  E5                    24     DEC
F010  EA 00                 25     OUT $00
F012  A9 FF FF              26     STB temp
F015  88 53                 27     CMPB #'S'    * compare to S
F017  D5 17                 28     SJNZ is_S    * it's an 'S' so jump to that handler
F019  09 FF FF              29     LDB temp
F01C  88 47                 30     CMPB #'G'
F01E  D5 46                 31     SJNZ is_G    * it's an 'G' jump there
F020  09 FF FF              32     LDB temp
F023  88 44                 33     CMPB #'D'
F025  D5 4F                 34     SJNZ is_D
F027  09 FF FF              35     LDB temp
F02A  88 42                 36     CMPB #'B'
F02C  D5 5D                 37     SJNZ is_B
F02E  D3 DA                 38     SJMP top     * ignore and jump to top
F030                        39  
F030                        40  * S records we need 
F030                        41  * 1. Read command '1' or '9'
F030                        42  * 2. Read 1 hex byte, n =  # of data + 3
F030                        43  * 3. Read 2 hex bytes (addr)
F030                        44  * 4. Read n - 3 hex bytes (data)
F030                        45  * 5. Read 1 hex byte (checksum)
F030                        46  is_S
F030  EB 00                 47     IN $00
F032  E4                    48     INC
F033  D4 FB                 49     SJZ is_S       * wait for a char (the command)
F035  E5                    50     DEC
F036  EA 00                 51     OUT $00
F038  D8 A0 F0              52     CALL read_hex  * read the # of bytes 'n'
F03B  28 03                 53     SUBB #3		  * sub addr/checksum
F03D  D4 CB                 54     SJZ top		  * no bytes to store so just exit out
F03F  A9 FC FF              55     STB temp4      * temp4 == n
F042  D8 A0 F0              56     CALL read_hex  * read addrhi
F045  A9 FB FF              57     STB addrhi
F048  D8 A0 F0              58     CALL read_hex  * read bottom
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 2

F04B  A9 FA FF              59     STB addr
F04E  91 FA FF              60     LDI addr       * INDEX = address to store to
F051                        61  is_S_loop
F051  D8 A0 F0              62     CALL read_hex
F054  AA                    63     STB I		  * store via index
F055  9B 01                 64     LEAI 1,I		  * increment iindex
F057  09 FC FF              65     LDB temp4      * load n
F05A  E5                    66     DEC
F05B  A9 FC FF              67     STB temp4
F05E  D5 F1                 68     SJNZ is_S_loop
F060  D8 A0 F0              69     CALL read_hex  * skip checksum
F063  D0 0A F0              70     JMP top
F066                        71     
F066                        72  is_G
F066  D8 A0 F0              73     CALL read_hex  * read address
F069  A9 FB FF              74     STB addrhi
F06C  D8 A0 F0              75     CALL read_hex
F06F  A9 FA FF              76     STB addr
F072  01 FA FF              77     LD addr        * jump to address
F075  D6                    78     IJMP
F076                        79  
F076                        80  is_D
F076  D8 A0 F0              81     CALL read_hex
F079  A9 FB FF              82     STB addrhi
F07C  D8 A0 F0              83     CALL read_hex
F07F  A9 FA FF              84     STB addr
F082  01 FA FF              85     LD addr
F085  D8 20 F1              86     CALL puthexline
F088  D0 0A F0              87     JMP top
F08B                        88     
F08B                        89  is_B
F08B  D8 A0 F0              90     CALL read_hex
F08E  A9 FB FF              91     STB addrhi
F091  D8 A0 F0              92     CALL read_hex
F094  A9 FA FF              93     STB addr
F097  01 FA FF              94     LD addr
F09A  D8 FA F0              95     CALL puthexblock
F09D  D0 0A F0              96     JMP top
F0A0                        97  
F0A0                        98  * read hex byte into ACC
F0A0                        99  read_hex
F0A0  E0                   100     CLR
F0A1  A9 FF FF             101     STB temp         * zero the temp byte
F0A4  08 02                102     LDB #2
F0A6  A9 FE FF             103     STB temp2        * zero nibble count
F0A9                       104  read_hex_top
F0A9  09 FF FF             105     LDB temp         * shift temp up 4 bits for next nibble
F0AC  C0 04                106     SHL #4
F0AE  A9 FF FF             107     STB temp
F0B1                       108  read_hex_loop
F0B1  EB 00                109     IN $00
F0B3  E4                   110     INC
F0B4  D4 FB                111     SJZ read_hex_loop * read from uart
F0B6  E5                   112     DEC
F0B7  EA 00                113     OUT $00          * echo back
F0B9  A9 FD FF             114     STB temp3		* save the char being read
F0BC  88 39                115     CMPB #'9'        * assume it's 0-9A-F
F0BE  CE                   116     UGT              * check for >'9'
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 3

F0BF  D5 16                117     SJNZ read_hex_af
F0C1  09 FD FF             118     LDB temp3        * readload byte
F0C4  28 30                119     SUBB #'0'		* it's 0-9
F0C6                       120  read_hex_store_nibble
F0C6  69 FF FF             121     ORB temp			* or with accumulated data
F0C9  A9 FF FF             122     STB temp         * store back
F0CC  09 FE FF             123     LDB temp2
F0CF  E5                   124     DEC
F0D0  A9 FE FF             125     STB temp2
F0D3  D5 D4                126     SJNZ read_hex_top
F0D5  D3 09                127     SJMP read_hex_end
F0D7                       128  read_hex_af
F0D7  09 FD FF             129     LDB temp3        * reload byte
F0DA  28 41                130     SUBB #'A'        * subtract 'A'
F0DC  18 0A                131     ADDB #10         * then normalize to 10..15
F0DE  D3 E6                132     SJMP read_hex_store_nibble
F0E0                       133  read_hex_end
F0E0  09 FF FF             134     LDB temp         * we're done
F0E3  D9                   135     RET
F0E4                       136  
F0E4                       137  * putstr in INDEX
F0E4                       138  putstr
F0E4  DC                   139  	PUSHA
F0E5  DD                   140  	PUSHI
F0E6                       141  putstrtop
F0E6  0A                   142  	LDB I
F0E7  D4 06                143  	SJZ putstr_end
F0E9  EA 00                144  	OUT $00
F0EB  9B 01                145      LEAI 1,I		  * increment iindex
F0ED  D3 F7                146  	SJMP putstrtop
F0EF                       147  putstr_end
F0EF  95                   148  	LDI S+
F0F0  08 0A                149  	LDB #10
F0F2  EA 00                150  	OUT $00
F0F4  08 0D                151  	LDB #13
F0F6  EA 00                152  	OUT $00
F0F8  05                   153  	LD S+
F0F9  D9                   154  	RET
F0FA                       155  
F0FA                       156  * display 16 lines at ACC
F0FA                       157  puthexblock
F0FA  DC                   158  	PUSHA				* 2,S == address
F0FB  00 10 00             159  	LD #16
F0FE  DC                   160  	PUSHA				* 0,S == number of lines 
F0FF                       161  puthexblock_top
F0FF  04 02                162  	LD 2,S
F101  D8 20 F1             163  	CALL puthexline
F104  10 10 00             164  	ADD #16
F107  A4 02                165  	ST 2,S				* increment by 16
F109  04 00                166  	LD 0,S
F10B  E5                   167  	DEC
F10C  A4 00                168  	ST 0,S
F10E  D2 FF F0             169  	JNZ puthexblock_top
F111  DB 02                170  	FREE 2
F113  08 0A                171  	LDB #10				* print newline/cr
F115  EA 00                172  	OUT $00
F117  08 0D                173  	LDB #13
F119  EA 00                174  	OUT $00
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 4

F11B  05                   175  	LD S+
F11C  20 00 01             176  	SUB #256			* subtract the 256 we added 
F11F  D9                   177  	RET
F120                       178  
F120                       179  * display 16 bytes at ACC
F120                       180  puthexline
F120  DD                   181  	PUSHI
F121  DC                   182  	PUSHA				* 2,S == address
F122  00 10 00             183  	LD #16
F125  DC                   184  	PUSHA				* 0,S == number of bytes to print
F126                       185  * display newline
F126  08 0A                186      LDB #10
F128  EA 00                187      OUT $00
F12A  08 0D                188      LDB #13
F12C  EA 00                189      OUT $00
F12E                       190  * display address and space
F12E  04 02                191  	LD 2,S
F130  B8 08                192  	SHR #8
F132  D8 5F F1             193      CALL puthex
F135  04 02                194  	LD 2,S
F137  D8 5F F1             195      CALL puthex
F13A  08 20                196      LDB #' '
F13C  EA 00                197      OUT $00
F13E                       198  * display 16 bytes
F13E  94 02                199  	LDI 2,S				* address
F140                       200  puthexline_top
F140  0A                   201  	LDB I				* read byte
F141  D8 5F F1             202  	CALL puthex
F144  08 20                203  	LDB #' '
F146  EA 00                204  	OUT $00
F148  04 02                205  	LD 2,S
F14A  E4                   206  	INC
F14B  A4 02                207  	ST 2,S
F14D  9B 01                208  	LEAI 1,I            * advance index
F14F  04 00                209  	LD 0,S
F151  E5                   210  	DEC
F152  A4 00                211  	ST 0,S
F154  D2 40 F1             212  	JNZ puthexline_top
F157  DB 02                213  	FREE 2
F159  05                   214  	LD S+
F15A  20 10 00             215      SUB #16				* subtract the 16 we added to it
F15D  95                   216  	LDI S+
F15E  D9                   217  	RET
F15F                       218  	
F15F                       219  * put hex from ACC
F15F                       220  puthex
F15F  DD                   221  	PUSHI
F160  DC                   222  	PUSHA				* save what we are printing 2,S
F161  00 02 00             223  	LD #2
F164  DC                   224  	PUSHA				* 0,S == # of digits to print
F165                       225  puthex_ch
F165  04 02                226  	LD 2,S
F167  B8 04                227  	SHR #4				* grab only 4 bits
F169  50 0F 00             228  	AND #$F
F16C  E6                   229  	TAI					* save it
F16D  88 09                230  	CMPB #9             * compare to 9
F16F  CE                   231  	UGT                 * greater than?
F170  D5 05                232  	SJNZ puthex_af
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 5

F172  E7                   233  	TIA                 * restore masked copy
F173  18 30                234  	ADDB #'0'           * it was 0-9 so map to '0'-'9'
F175  D3 05                235  	SJMP puthex_bot
F177                       236  puthex_af
F177  E7                   237      TIA
F178  28 0A                238      SUBB #10
F17A  18 41                239      ADDB #'A'           * restore and normalize to 'A'-'F'
F17C                       240  puthex_bot
F17C  EA 00                241      out $00
F17E  04 02                242      LD 2,S
F180  C0 04                243      SHL #4
F182  A4 02                244      ST 2,S              * shift right 4 bits
F184  04 00                245      LD 0,S
F186  E5                   246      DEC
F187  A4 00                247      ST 0,S
F189  D5 DA                248      SJNZ puthex_ch
F18B  DB 02                249      FREE 2
F18D  05                   250      LD S+
F18E  95                   251      LDI S+
F18F  D9                   252      RET
F190  43 2D 46 4C 45 41 +  253  ?WELCOMSTR STR "C-FLEA Primer25K monitor -- Tom St Denis"

DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 1

0000                         1  * BOOT ROM for C-FLEA on Primer 25K
0000                         2  * Parses basic S records (S1 and S9) as well as Gxxxx command to run programs
0000                         3  
0000                         4  * we have 2KB of ROM starting at F000
F000                         5     ORG $F000
F000                         6  
F000                         7  * some variables to keep state, let's hide them at the end of video mem
FFFF                         8  temp EQU $FFFF    * temp variables
FFFE                         9  temp2 EQU $FFFE
FFFC                        10  addr EQU $FFFC    * we can 16-bit load the addr from here
FFFD                        11  addrhi EQU $FFFD  * and write to the top half here
F900                        12  stack EQU $F900   * stack inside the video so we have something to see
F000                        13  
F000  00 00 F9              14     LD #stack
F003  DE                    15     TAS          * SP = stack (F900)
F004                        16  top
F004  EB 00                 17     IN $00       * read from UART
F006  D4 FC                 18     SJZ top      * loop while no char
F008  88 53                 19     CMPB #'S'    * compare to S
F00A  D2 14 F0              20     JNZ is_S     * it's an 'S' so jump to that handler
F00D  88 47                 21     CMPB #'G'
F00F  D2 45 F0              22     JNZ is_G     * it's an 'G' jump there
F012  D3 F0                 23     SJMP top     * ignore and jump to top
F014                        24  
F014                        25  * S records we need 
F014                        26  * 1. Read command '1' or '9'
F014                        27  * 2. Read 1 hex byte, n =  # of data + 3
F014                        28  * 3. Read 2 hex bytes (addr)
F014                        29  * 4. Read n - 3 hex bytes (data)
F014                        30  * 5. Read 1 hex byte (checksum)
F014                        31  is_S
F014  EB 00                 32     IN $00
F016  D4 FC                 33     SJZ is_S       * wait for a char (the command)
F018  D8 55 F0              34     CALL read_hex  * read the # of bytes 'n'
F01B  28 03                 35     SUBB #3		  * sub addr/checksum
F01D  A9 FE FF              36     STB temp2      * temp2 == n
F020  D8 55 F0              37     CALL read_hex  * read addrhi
F023  A9 FD FF              38     STB addrhi
F026  D8 55 F0              39     CALL read_hex  * read bottom
F029  A9 FC FF              40     STB addr
F02C  91 FC FF              41     LDI addr       * INDEX = address to store to
F02F                        42  is_S_loop
F02F  D8 55 F0              43     CALL read_hex
F032  AA                    44     STB I		  * store via index
F033  E7                    45     TIA			  * increment index
F034  E4                    46     INC
F035  E6                    47     TAI
F036  09 FE FF              48     LDB temp2      * load n
F039  E5                    49     DEC
F03A  A9 FE FF              50     STB temp2
F03D  D5 F0                 51     SJNZ is_S_loop
F03F  D8 55 F0              52     CALL read_hex  * skip checksum
F042  D0 04 F0              53     JMP top
F045                        54     
F045                        55  is_G
F045  D8 55 F0              56     CALL read_hex  * read address
F048  A9 FD FF              57     STB addrhi
F04B  D8 55 F0              58     CALL read_hex
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 2

F04E  A9 FC FF              59     STB addr
F051  01 FC FF              60     LD addr        * jump to address
F054  D6                    61     IJMP
F055                        62  
F055                        63  * read hex byte into ACC
F055                        64  read_hex EQU *
F055  E0                    65     CLR
F056  A9 FF FF              66     STB temp         * zero the temp byte
F059  08 02                 67     LDB #2
F05B  A9 FE FF              68     STB temp2        * zero nibble count
F05E                        69  read_hex_top
F05E  09 FF FF              70     LDB temp         * shift temp up 4 bits for next nibble
F061  C0 04                 71     SHL #4
F063  A9 FF FF              72     STB temp
F066                        73  read_hex_loop
F066  EB 00                 74     IN $00
F068  D4 FC                 75     SJZ read_hex_loop
F06A  88 39                 76     CMPB #'9'
F06C  CE                    77     UGT
F06D  D5 13                 78     SJNZ read_hex_af
F06F  28 30                 79     SUBB #'0'		* it's 0-9
F071                        80  read_hex_store_nibble
F071  69 FF FF              81     ORB temp			* or with accumulated data
F074  A9 FF FF              82     STB temp         * store back
F077  09 FE FF              83     LDB temp2
F07A  E5                    84     DEC
F07B  A9 FE FF              85     STB temp2
F07E  D5 DE                 86     SJNZ read_hex_top
F080  D3 06                 87     SJMP read_hex_end
F082                        88  read_hex_af
F082  28 41                 89     SUBB #'A'        * subtract 'A'
F084  18 0A                 90     ADDB #10         * then normalize to 10..15
F086  D3 E9                 91     SJMP read_hex_store_nibble
F088                        92  read_hex_end
F088  09 FF FF              93     LDB temp         * we're done
F08B  D9                    94     RET
F08C                        95  

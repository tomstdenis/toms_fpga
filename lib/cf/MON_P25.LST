DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 1

0000                         1  * BOOT ROM for C-FLEA on Primer 25K
0000                         2  * Parses basic S records as well as
0000                         3  * - Gxxxx command to run programs (jumps to xxxx)
0000                         4  * - Dxxxx to dump 16 bytes 
0000                         5  * - Bxxxx to dump 256 bytes
0000                         6  
0000                         7  * we have 2KB of ROM starting at F000
F000                         8     ORG $F000
F000                         9  
F000                        10  * some variables to keep state, let's hide them at the end of video mem
FFFF                        11  temp EQU $FFFF    * temp variables
FFFE                        12  temp2 EQU $FFFE
FFFD                        13  temp3 EQU $FFFD
FFFC                        14  temp4 EQU $FFFC   * n
FFFA                        15  addr EQU $FFFA    * we can 16-bit load the addr from here
FFFB                        16  addrhi EQU $FFFB  * and write to the top half here
F900                        17  stack EQU $F900   * stack inside the video so we have something to see
F000                        18  
F000  00 00 F9              19      LD #stack
F003  DE                    20      TAS             * SP = stack (F900)
F004  99 67 F1              21      LEAI ?WELCOMSTR
F007  D8 B6 F0              22      CALL putstr
F00A                        23  top
F00A  D8 60 F1              24      CALL getch
F00D  E6                    25      TAI
F00E  88 53                 26      CMPB #'S'     * compare to S
F010  D5 11                 27      SJNZ is_S     * it's an 'S' so jump to that handler
F012  E7                    28      TIA
F013  88 47                 29      CMPB #'G'
F015  D5 3C                 30      SJNZ is_G     * it's an 'G' jump there
F017  E7                    31      TIA
F018  88 44                 32      CMPB #'D'
F01A  D5 3B                 33      SJNZ is_D
F01C  E7                    34      TIA
F01D  88 42                 35      CMPB #'B'
F01F  D5 3E                 36      SJNZ is_B
F021  D3 E7                 37      SJMP top      * ignore and jump to top
F023                        38  
F023                        39  * S records we need 
F023                        40  * 1. Read command '1' or '9'
F023                        41  * 2. Read 1 hex byte, n =  # of data + 3
F023                        42  * 3. Read 2 hex bytes (addr)
F023                        43  * 4. Read n - 3 hex bytes (data)
F023                        44  * 5. Read 1 hex byte (checksum)
F023                        45  is_S
F023  D8 60 F1              46      CALL getch
F026  D8 77 F0              47      CALL read_hex  	* read the # of bytes 'n'
F029  28 03                 48      SUBB #3		  	* sub addr/checksum
F02B  D4 DD                 49      SJZ top		  	* no bytes to store so just exit out
F02D  A9 FC FF              50      STB temp4       * temp4 == n
F030  D8 77 F0              51      CALL read_hex  	* read addrhi
F033  A9 FB FF              52      STB addrhi
F036  D8 77 F0              53      CALL read_hex	* read bottom
F039  A9 FA FF              54      STB addr
F03C  91 FA FF              55      LDI addr        * INDEX = address to store to
F03F                        56  is_S_loop
F03F  D8 77 F0              57      CALL read_hex
F042  AA                    58      STB I		  	* store via index
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 2

F043  9B 01                 59      LEAI 1,I		* increment iindex
F045  09 FC FF              60      LDB temp4       * load n
F048  E5                    61      DEC
F049  A9 FC FF              62      STB temp4
F04C  D5 F1                 63      SJNZ is_S_loop
F04E  D8 77 F0              64      CALL read_hex	* skip checksum
F051  D3 B7                 65      SJMP top
F053                        66      
F053                        67  is_G
F053  D8 67 F0              68      CALL read_addr
F056  D6                    69      IJMP
F057                        70  
F057                        71  is_D
F057  D8 67 F0              72      CALL read_addr
F05A  D8 F1 F0              73      CALL puthexline
F05D  D3 AB                 74      SJMP top
F05F                        75      
F05F                        76  is_B
F05F  D8 67 F0              77      CALL read_addr
F062  D8 CC F0              78      CALL puthexblock
F065  D3 A3                 79      SJMP top
F067                        80      
F067                        81  * read address into addr
F067                        82  read_addr
F067  D8 77 F0              83      CALL read_hex
F06A  A9 FB FF              84      STB addrhi
F06D  D8 77 F0              85      CALL read_hex
F070  A9 FA FF              86      STB addr
F073  01 FA FF              87      LD addr
F076  D9                    88      RET
F077                        89  
F077                        90  * read hex byte into ACC
F077                        91  read_hex
F077  E0                    92      CLR
F078  A9 FF FF              93      STB temp            * zero the temp byte
F07B  08 02                 94      LDB #2
F07D  A9 FE FF              95      STB temp2          	* zero nibble count
F080                        96  read_hex_top
F080  09 FF FF              97      LDB temp            * shift temp up 4 bits for next nibble
F083  C0 04                 98      SHL #4
F085  A9 FF FF              99      STB temp
F088                       100  read_hex_loop
F088  D8 60 F1             101      CALL getch
F08B  A9 FD FF             102      STB temp3			* save the char being read
F08E  88 39                103      CMPB #'9'          	* assume it's 0-9A-F
F090  CE                   104      UGT                 * check for >'9'
F091  D5 16                105      SJNZ read_hex_af
F093  09 FD FF             106      LDB temp3          	* readload byte
F096  28 30                107      SUBB #'0'			* it's 0-9
F098                       108  read_hex_store_nibble
F098  69 FF FF             109      ORB temp			* or with accumulated data
F09B  A9 FF FF             110      STB temp            * store back
F09E  09 FE FF             111      LDB temp2
F0A1  E5                   112      DEC
F0A2  A9 FE FF             113      STB temp2
F0A5  D5 D9                114      SJNZ read_hex_top
F0A7  D3 09                115      SJMP read_hex_end
F0A9                       116  read_hex_af
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 3

F0A9  09 FD FF             117      LDB temp3          	* reload byte
F0AC  28 41                118      SUBB #'A'          	* subtract 'A'
F0AE  18 0A                119      ADDB #10            * then normalize to 10..15
F0B0  D3 E6                120      SJMP read_hex_store_nibble
F0B2                       121  read_hex_end
F0B2  09 FF FF             122      LDB temp            * we're done
F0B5  D9                   123      RET
F0B6                       124  
F0B6                       125  * putstr in INDEX
F0B6                       126  putstr
F0B6  DC                   127  	PUSHA
F0B7  DD                   128  	PUSHI
F0B8                       129  putstrtop
F0B8  0A                   130  	LDB I
F0B9  D4 06                131  	SJZ putstr_end
F0BB  EA 00                132  	OUT $00
F0BD  9B 01                133      LEAI 1,I		  * increment iindex
F0BF  D3 F7                134  	SJMP putstrtop
F0C1                       135  putstr_end
F0C1  95                   136  	LDI S+
F0C2  08 0A                137  	LDB #10
F0C4  EA 00                138  	OUT $00
F0C6  08 0D                139  	LDB #13
F0C8  EA 00                140  	OUT $00
F0CA  05                   141  	LD S+
F0CB  D9                   142  	RET
F0CC                       143  
F0CC                       144  * display 16 lines at ACC
F0CC                       145  puthexblock
F0CC  DC                   146  	PUSHA				* 2,S == address
F0CD  00 10 00             147  	LD #16
F0D0  DC                   148  	PUSHA				* 0,S == number of lines 
F0D1                       149  puthexblock_top
F0D1  04 02                150  	LD 2,S
F0D3  D8 F1 F0             151  	CALL puthexline
F0D6  10 10 00             152  	ADD #16
F0D9  A4 02                153  	ST 2,S				* increment by 16
F0DB  04 00                154  	LD 0,S
F0DD  E5                   155  	DEC
F0DE  A4 00                156  	ST 0,S
F0E0  D5 EF                157  	SJNZ puthexblock_top
F0E2  DB 02                158  	FREE 2
F0E4  08 0A                159  	LDB #10				* print newline/cr
F0E6  EA 00                160  	OUT $00
F0E8  08 0D                161  	LDB #13
F0EA  EA 00                162  	OUT $00
F0EC  05                   163  	LD S+
F0ED  20 00 01             164  	SUB #256			* subtract the 256 we added 
F0F0  D9                   165  	RET
F0F1                       166  
F0F1                       167  * display 16 bytes at ACC
F0F1                       168  puthexline
F0F1  DD                   169  	PUSHI
F0F2  DC                   170  	PUSHA				* 2,S == address
F0F3  00 10 00             171  	LD #16
F0F6  DC                   172  	PUSHA				* 0,S == number of bytes to print
F0F7                       173  * display newline
F0F7  08 0A                174      LDB #10
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 4

F0F9  EA 00                175      OUT $00
F0FB  08 0D                176      LDB #13
F0FD  EA 00                177      OUT $00
F0FF                       178  * display address and space
F0FF  04 02                179  	LD 2,S
F101  B8 08                180  	SHR #8
F103  D8 2F F1             181      CALL puthex
F106  04 02                182  	LD 2,S
F108  D8 2F F1             183      CALL puthex
F10B  08 20                184      LDB #' '
F10D  EA 00                185      OUT $00
F10F                       186  * display 16 bytes
F10F  94 02                187  	LDI 2,S				* address
F111                       188  puthexline_top
F111  0A                   189  	LDB I				* read byte
F112  D8 2F F1             190  	CALL puthex
F115  08 20                191  	LDB #' '
F117  EA 00                192  	OUT $00
F119  04 02                193  	LD 2,S
F11B  E4                   194  	INC
F11C  A4 02                195  	ST 2,S
F11E  9B 01                196  	LEAI 1,I            * advance index
F120  04 00                197  	LD 0,S
F122  E5                   198  	DEC
F123  A4 00                199  	ST 0,S
F125  D5 EA                200  	SJNZ puthexline_top
F127  DB 02                201  	FREE 2
F129  05                   202  	LD S+
F12A  20 10 00             203      SUB #16				* subtract the 16 we added to it
F12D  95                   204  	LDI S+
F12E  D9                   205  	RET
F12F                       206  	
F12F                       207  * put hex from ACC
F12F                       208  puthex
F12F  DD                   209  	PUSHI
F130  DC                   210  	PUSHA				* save what we are printing 2,S
F131  00 02 00             211  	LD #2
F134  DC                   212  	PUSHA				* 0,S == # of digits to print
F135                       213  puthex_ch
F135  04 02                214  	LD 2,S
F137  B8 04                215  	SHR #4				* grab only 4 bits
F139  50 0F 00             216  	AND #$F
F13C  E6                   217  	TAI					* save it
F13D  88 09                218  	CMPB #9             * compare to 9
F13F  CE                   219  	UGT                 * greater than?
F140  D5 05                220  	SJNZ puthex_af
F142  E7                   221  	TIA                 * restore masked copy
F143  18 30                222  	ADDB #'0'           * it was 0-9 so map to '0'-'9'
F145  D3 05                223  	SJMP puthex_bot
F147                       224  puthex_af
F147  E7                   225      TIA
F148  28 0A                226      SUBB #10
F14A  18 41                227      ADDB #'A'           * restore and normalize to 'A'-'F'
F14C                       228  puthex_bot
F14C  EA 00                229      out $00
F14E  04 02                230      LD 2,S
F150  C0 04                231      SHL #4
F152  A4 02                232      ST 2,S              * shift right 4 bits
DUNFIELD CFLEA ASSEMBLER: MON_P25                                      PAGE: 5

F154  04 00                233      LD 0,S
F156  E5                   234      DEC
F157  A4 00                235      ST 0,S
F159  D5 DA                236      SJNZ puthex_ch
F15B  DB 02                237      FREE 2
F15D  05                   238      LD S+
F15E  95                   239      LDI S+
F15F  D9                   240      RET
F160                       241      
F160                       242  getch
F160  EB 00                243      IN $00        * read from UART
F162  E4                   244      INC
F163  D4 FB                245      SJZ getch     * loop while no char
F165  E5                   246      DEC
F166  D9                   247      RET
F167                       248  
F167  43 2D 46 4C 45 41 +  249  ?WELCOMSTR STR "C-FLEA Primer25K monitor -- Tom St Denis"
F18F                       250  ROM_END EQU *

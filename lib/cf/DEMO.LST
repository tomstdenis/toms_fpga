1B7D  58 7F               1454  	ANDB	#%001111111	Free format?
1B7F  D4 05               1455  	SJZ	?AG17		Yes, ignore
1B81  0C 02               1456  	LDB	2+?AG6,S		Get value back
1B83  E5                  1457  	DEC			Adjust for '-'
1B84  AC 02               1458  	STB	2+?AG6,S		Resave
1B86                      1459  * '%u' - Unsigned decimal number
1B86  08 0A               1460  ?AG17	LDB	#10		Base 10 output
1B88  D3 02               1461  	SJMP	?AG19		Do number
1B8A                      1462  * '%x' - heXidecimal number
1B8A  08 10               1463  ?AG18	LDB	#16		Base 16 output
1B8C                      1464  * Output a number in the specified number base
1B8C  AC 06               1465  ?AG19	STB	2+?AG3,S		Save number base
1B8E  9C 0C               1466  	LEAI	6+2+?AG3,S	Point to END of buffer
1B90  E7                  1467  ?AG20	TIA			Get index
1B91  E5                  1468  	DEC			Backup
1B92  E6                  1469  	TAI			Set index
1B93  0C 03               1470  	LDB	2+?AG5,S		Get count
1B95  E4                  1471  	INC			Advance
1B96  AC 03               1472  	STB	2+?AG5,S		Resave
1B98  04 04               1473  	LD	2+?AG4,S		Get value
1B9A  4C 06               1474  	DIVB	2+?AG3,S		Divide by 10
1B9C  DC                  1475  	PUSHA			Save quotient
1B9D  E9                  1476  	ALT			Get remainder
1B9E  18 30               1477  	ADDB	#'0'		Convert to ASCII
1BA0  AA                  1478  	STB	I		Write to stack
1BA1  88 39               1479  	CMPB	#'9'		Is it HEX?
1BA3  CE                  1480  	UGT			Complete test
1BA4  D4 04               1481  	SJZ	?AG21		Yes it is
1BA6  0A                  1482  	LDB	I		Get char back
1BA7  18 07               1483  	ADDB	#7		Adjust
1BA9  AA                  1484  	STB	I		Resave char
1BAA  05                  1485  ?AG21	LD	S+		Get quotient
1BAB  A4 04               1486  	ST	2+?AG4,S		Save new value
1BAD  D5 E1               1487  	SJNZ	?AG20		Do them all
1BAF                      1488  * At this point, I = pointer, ?5=Length
1BAF  0C 03               1489  ?AG22	LDB	2+?AG5,S		Get count
1BB1  AC 05               1490  	STB	3+?AG4,S		Set extra count
1BB3  0C 02               1491  	LDB	2+?AG6,S		Get flag
1BB5  58 80               1492  	ANDB	#%10000000	Left justify?
1BB7  D5 03               1493  	SJNZ	?AG23		Yes, don't fill
1BB9  D8 FD 1B            1494  	CALL	?AG31		Do any pre-output
1BBC  0C 05               1495  ?AG23	LDB	3+?AG4,S		Get count
1BBE  D4 11               1496  	SJZ	?AG24		All done, exit
1BC0  E5                  1497  	DEC			Reduce count
1BC1  AC 05               1498  	STB	3+?AG4,S		Resave
1BC3  0A                  1499  	LDB	I		Get character from string
1BC4  9B 01               1500  	LEAI	1,I		Advance
1BC6  DD                  1501  	PUSHI			Save it
1BC7  DC                  1502  	PUSHA			Pass character
1BC8  04 12               1503  	LD	6+?AG1,S		Get output function
1BCA  D8 F9 1A            1504  	CALL	?AG9		Output character
1BCD  05                  1505  	LD	S+		Clean stack
1BCE  95                  1506  	LDI	S+		Restore I
1BCF  D3 EB               1507  	SJMP	?AG23		Go again
1BD1  0C 02               1508  ?AG24	LDB	2+?AG6,S		Get flag
DUNFIELD CFLEA ASSEMBLER: DEMO                                         PAGE: 27

1BD3  58 80               1509  	ANDB	#%10000000	Left justify
1BD5  D4 03               1510  	SJZ	?AG25		No, skip it
1BD7  D8 FD 1B            1511  	CALL	?AG31		Post justify
1BDA  95                  1512  ?AG25	LDI	S+		Restore format string
1BDB  9B 01               1513  	LEAI	1,I		Advance pointer
1BDD  D0 E1 1A            1514  	JMP	?AG7		And proceed
1BE0                      1515  * '%c' - output character
1BE0  0C 04               1516  ?AG26	LDB	2+?AG4,S		Get character
1BE2  9C 06               1517  ?AG27	LEAI	2+?AG3,S		Point to buffer
1BE4  AA                  1518  	STB	I		Save it
1BE5  08 01               1519  	LDB	#1		Get 1
1BE7  AC 03               1520  	STB	2+?AG5,S
1BE9  D3 C4               1521  	SJMP	?AG22
1BEB                      1522  * '%s' - output string
1BEB  94 04               1523  ?AG28	LDI	2+?AG4,S		Get string pointer
1BED  0A                  1524  ?AG29	LDB	I		Get character
1BEE  D4 09               1525  	SJZ	?AG30		End of string
1BF0  9B 01               1526  	LEAI	1,I		Skip to next
1BF2  0C 03               1527  	LDB	2+?AG5,S		Get count
1BF4  E4                  1528  	INC			Advance

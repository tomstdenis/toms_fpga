1BA8  58 80               1480  	ANDB	#%10000000	Left justify
1BAA  D4 03               1481  	SJZ	?AG25		No, skip it
1BAC  D8 D2 1B            1482  	CALL	?AG31		Post justify
1BAF  95                  1483  ?AG25	LDI	S+		Restore format string
1BB0  9B 01               1484  	LEAI	1,I		Advance pointer
1BB2  D0 B6 1A            1485  	JMP	?AG7		And proceed
1BB5                      1486  * '%c' - output character

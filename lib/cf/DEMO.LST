1BF7  D3 F4               1530  	SJMP	?AG29		And proceed
1BF9  94 04               1531  ?AG30	LDI	2+?AG4,S		Get pointer back
1BFB  D3 B2               1532  	SJMP	?AG22		And output
1BFD                      1533  * Perform pre-output justify
1BFD  0C 04               1534  ?AG31	LDB	4+?AG6,S		Get flag
1BFF  58 3F               1535  	ANDB	#%00111111	Save length only
1C01  D4 23               1536  	SJZ	?AG35		No justify
1C03  AC 06               1537  	STB	4+?AG4,S		Save for later
1C05  DD                  1538  	PUSHI			Save index
1C06  0C 07               1539  ?AG32	LDB	6+?AG5,S		Get count
1C08  8C 08               1540  	CMPB	6+?AG4,S		Are we over
1C0A  CF                  1541  	UGE			Complete test
1C0B  D5 18               1542  	SJNZ	?AG34		Yes, exit
1C0D  0C 06               1543  	LDB	6+?AG6,S		Get flag
1C0F  58 40               1544  	ANDB	#%01000000	Zero fill?
1C11  D4 02               1545  	SJZ	?AG33		No, use ' '
1C13  08 10               1546  	LDB	#'0'-' '	Get value
1C15  18 20               1547  ?AG33	ADDB	#' '		Convert to char
1C17  DC                  1548  	PUSHA			Pass character
1C18  04 14               1549  	LD	8+?AG1,S		Get output function

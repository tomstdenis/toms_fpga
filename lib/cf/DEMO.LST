1000                         8  	ORG	$1000		Place code in memory here
1000                         9  * Begin execution here... Setup stack, zero heap & call main()
1000  00 00 10              10  	LD	#*		Stack below here
1003  DE                    11  	TAS			Set up stack
1004  E0                    12  	CLR			Get zero
1005  A9 62 04              13  	STB	?heap		Zero heap
1008  D8 4A 11              14  	CALL	main		Run main program
100B                        15  * Most embedded programs will never return or exit, however if they
100B                        16  * do, this section of code should do something appropriate, either
100B                        17  * restart the program, or stop the machine. For this system, we will
100B                        18  * simply freeze by entering an infinite loop.
100B  D3 FE                 19  exit	SJMP	*		Loop forever
100D                        20  *50000 22/5/2026
100D                        21  wait_us EQU *

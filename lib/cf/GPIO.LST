1D70                      1926  *
1D70  EB 00               1927  chkchr	IN	0		Read port 0
1D72  D9                  1928  	RET
1D73                      1929  *
1D73                      1930  * Get string from console (with editing): getstr(string, size)
1D73                      1931  *
1D73  E0                  1932  getstr	CLR			Zero length
1D74  DC                  1933  	PUSHA			Save on stack
1D75  D8 58 1D            1934  ?AG3	CALL	getchr		Get a character
1D78  90 7C 1D            1935  	LDI	#?AG4		Point to table
1D7B  D7                  1936  	SWITCH			Dispatch
1D7C  A5 1D 08 00         1937  ?AG4	FDB	?AG6,$08		Backspace
1D80  A5 1D 7F 00         1938  	FDB	?AG6,$7F		Delete
1D84  B4 1D 0D 00         1939  	FDB	?AG7,$0D		Return
1D88  00 00 8C 1D         1940  	FDB	0,?AG5		Default
1D8C                      1941  * Normal character
1D8C  A9 00 00            1942  ?AG5	STB	?temp		Save for later
1D8F  04 00               1943  	LD	,S		Get current position
1D91  84 04               1944  	CMP	4,S		Are we OK
1D93  CF                  1945  	UGE			Test for over
1D94  D5 DF               1946  	SJNZ	?AG3		Ignore
1D96  94 06               1947  	LDI	6,S		Get pointer
1D98  05                  1948  	LD	S+		Get size
1D99  E8                  1949  	ADAI			Adjust pointer
1D9A  E4                  1950  	INC			Advance count
1D9B  DC                  1951  	PUSHA			Resave
1D9C  09 00 00            1952  	LDB	?temp		Get char back
1D9F  AA                  1953  	STB	I		Save in buffer
1DA0  D8 4F 1D            1954  	CALL	?putchr		Echo it
1DA3  D3 D0               1955  	SJMP	?AG3		And proceed
1DA5                      1956  * Backspace & delete
1DA5  04 00               1957  ?AG6	LD	,S		Get count
1DA7  D4 CC               1958  	SJZ	?AG3		At zero, ignore
1DA9  E5                  1959  	DEC			Backup
1DAA  A4 00               1960  	ST	,S		Resave
1DAC  90 BE 1D            1961  	LDI	#?AG8		Point to message
1DAF  D8 35 1D            1962  	CALL	?putstr		Output
1DB2  D3 C1               1963  	SJMP	?AG3		And proceed
1DB4                      1964  * RETURN, terminate entry
1DB4  94 06               1965  ?AG7	LDI	6,S		Get buffer pointer
1DB6  05                  1966  	LD	S+		Get count
1DB7  E8                  1967  	ADAI			Adjust pointer
1DB8  E0                  1968  	CLR			Get zero
1DB9  AA                  1969  	STB	I		Terminate buffer
1DBA  08 0A               1970  	LDB	#$0A		Newline
1DBC  D3 91               1971  	SJMP	?putchr		Output
1DBE  08 20 08 00         1972  ?AG8	FCB	$08,' ',$08,0

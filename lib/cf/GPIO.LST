1EC1                      1828  *
1EC1                      1829  * Output character to console with newline translation: putch(c)
1EC1                      1830  *
1EC1  04 02               1831  putch	LD	2,S		Get character
1EC3  80 0A 00            1832  ?putch	CMP	#$0A		Newline?
1EC6  D4 05               1833  	SJZ	putchr		No, don't process
1EC8  08 0D               1834  	LDB	#$0D		Get RETURN
1ECA  D8 CF 1E            1835  	CALL	?putchr		Output it
1ECD                      1836  *
1ECD                      1837  * Output 'raw' character to console: putchr(c)
1ECD                      1838  *
1ECD  04 02               1839  putchr	LD	2,S		Get character
1ECF  EA 00               1840  ?putchr	OUT	0		Write to console
1ED1  D9                  1841  	RET
1ED2                      1842  *
1ED2                      1843  * Read a character from console with newline translation: getch()
1ED2                      1844  *
1ED2  D8 DF 1E            1845  getch	CALL	chkch		Test for character ready
1ED5  D4 FB               1846  	SJZ	getch		Wait for it
1ED7  D9                  1847  	RET
1ED8                      1848  *
1ED8                      1849  * Read 'raw' character from console: getchr()
1ED8                      1850  *
1ED8  EB 00               1851  getchr	IN	0		Read console port
1EDA  E4                  1852  	INC			Test for character
1EDB  D4 FB               1853  	SJZ	getchr		Wait for character
1EDD  E5                  1854  	DEC			Restore proper character
1EDE  D9                  1855  	RET
1EDF                      1856  *
DUNFIELD CFLEA ASSEMBLER: GPIO                                         PAGE: 33

1EDF                      1857  * Check for character from the console with translation: chkch()
1EDF                      1858  *
1EDF  EB 00               1859  chkch	IN	0		Read port 0
1EE1  E4                  1860  	INC			Test for char
1EE2  D4 0B               1861  	SJZ	?AG2		None, exit
1EE4  E5                  1862  	DEC			Restore proper char
1EE5  DC                  1863  	PUSHA			Save for later
1EE6  88 0D               1864  	CMPB	#$0D		RETURN?
1EE8  D4 04               1865  	SJZ	?AG1		No, its OK
1EEA  05                  1866  	LD	S+		Clean stack
1EEB  08 0A               1867  	LDB	#$0A		Get NEWLINE
1EED  D9                  1868  	RET
1EEE  05                  1869  ?AG1	LD	S+		Get char back
1EEF  D9                  1870  ?AG2	RET
1EF0                      1871  *
1EF0                      1872  * Check for 'raw' character from the console: chkchr()
1EF0                      1873  *
1EF0  EB 00               1874  chkchr	IN	0		Read port 0
1EF2  D9                  1875  	RET
1EF3                      1876  *
1EF3                      1877  * Get string from console (with editing): getstr(string, size)
1EF3                      1878  *
1EF3  E0                  1879  getstr	CLR			Zero length
1EF4  DC                  1880  	PUSHA			Save on stack
1EF5  D8 D8 1E            1881  ?AG3	CALL	getchr		Get a character
1EF8  90 FC 1E            1882  	LDI	#?AG4		Point to table
1EFB  D7                  1883  	SWITCH			Dispatch
1EFC  25 1F 08 00         1884  ?AG4	FDB	?AG6,$08		Backspace
1F00  25 1F 7F 00         1885  	FDB	?AG6,$7F		Delete
1F04  34 1F 0D 00         1886  	FDB	?AG7,$0D		Return
1F08  00 00 0C 1F         1887  	FDB	0,?AG5		Default
1F0C                      1888  * Normal character
1F0C  A9 00 00            1889  ?AG5	STB	?temp		Save for later
1F0F  04 00               1890  	LD	,S		Get current position
1F11  84 04               1891  	CMP	4,S		Are we OK
1F13  CF                  1892  	UGE			Test for over
1F14  D5 DF               1893  	SJNZ	?AG3		Ignore
1F16  94 06               1894  	LDI	6,S		Get pointer
1F18  05                  1895  	LD	S+		Get size
1F19  E8                  1896  	ADAI			Adjust pointer
1F1A  E4                  1897  	INC			Advance count
1F1B  DC                  1898  	PUSHA			Resave
1F1C  09 00 00            1899  	LDB	?temp		Get char back
1F1F  AA                  1900  	STB	I		Save in buffer
1F20  D8 CF 1E            1901  	CALL	?putchr		Echo it
1F23  D3 D0               1902  	SJMP	?AG3		And proceed
1F25                      1903  * Backspace & delete
1F25  04 00               1904  ?AG6	LD	,S		Get count
1F27  D4 CC               1905  	SJZ	?AG3		At zero, ignore
1F29  E5                  1906  	DEC			Backup
1F2A  A4 00               1907  	ST	,S		Resave
1F2C  90 3E 1F            1908  	LDI	#?AG8		Point to message
1F2F  D8 B5 1E            1909  	CALL	?putstr		Output
1F32  D3 C1               1910  	SJMP	?AG3		And proceed
1F34                      1911  * RETURN, terminate entry
1F34  94 06               1912  ?AG7	LDI	6,S		Get buffer pointer
1F36  05                  1913  	LD	S+		Get count
1F37  E8                  1914  	ADAI			Adjust pointer
DUNFIELD CFLEA ASSEMBLER: GPIO                                         PAGE: 34

1F38  E0                  1915  	CLR			Get zero
1F39  AA                  1916  	STB	I		Terminate buffer
1F3A  08 0A               1917  	LDB	#$0A		Newline
1F3C  D3 91               1918  	SJMP	?putchr		Output

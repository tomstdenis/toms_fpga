1D9B                      1932  *
1D9B  04 02               1933  putchr	LD	2,S		Get character
1D9D  EA 00               1934  ?putchr	OUT	0		Write to console
1D9F  D9                  1935  	RET
1DA0                      1936  *
1DA0                      1937  * Read a character from console with newline translation: getch()
1DA0                      1938  *
1DA0  D8 AD 1D            1939  getch	CALL	chkch		Test for character ready
1DA3  D4 FB               1940  	SJZ	getch		Wait for it
1DA5  D9                  1941  	RET
1DA6                      1942  *
1DA6                      1943  * Read 'raw' character from console: getchr()
1DA6                      1944  *
1DA6  EB 00               1945  getchr	IN	0		Read console port
1DA8  E4                  1946  	INC			Test for character
1DA9  D4 FB               1947  	SJZ	getchr		Wait for character
1DAB  E5                  1948  	DEC			Restore proper character
1DAC  D9                  1949  	RET
1DAD                      1950  *
1DAD                      1951  * Check for character from the console with translation: chkch()
1DAD                      1952  *
1DAD  EB 00               1953  chkch	IN	0		Read port 0
1DAF  E4                  1954  	INC			Test for char
1DB0  D4 0B               1955  	SJZ	?AG2		None, exit
1DB2  E5                  1956  	DEC			Restore proper char
1DB3  DC                  1957  	PUSHA			Save for later
1DB4  88 0D               1958  	CMPB	#$0D		RETURN?
1DB6  D4 04               1959  	SJZ	?AG1		No, its OK
1DB8  05                  1960  	LD	S+		Clean stack
1DB9  08 0A               1961  	LDB	#$0A		Get NEWLINE
1DBB  D9                  1962  	RET
1DBC  05                  1963  ?AG1	LD	S+		Get char back
1DBD  D9                  1964  ?AG2	RET
1DBE                      1965  *
1DBE                      1966  * Check for 'raw' character from the console: chkchr()
1DBE                      1967  *
1DBE  EB 00               1968  chkchr	IN	0		Read port 0
1DC0  D9                  1969  	RET
1DC1                      1970  *
1DC1                      1971  * Get string from console (with editing): getstr(string, size)
1DC1                      1972  *
DUNFIELD CFLEA ASSEMBLER: GPIO                                         PAGE: 35

1DC1  E0                  1973  getstr	CLR			Zero length
1DC2  DC                  1974  	PUSHA			Save on stack
1DC3  D8 A6 1D            1975  ?AG3	CALL	getchr		Get a character
1DC6  90 CA 1D            1976  	LDI	#?AG4		Point to table
1DC9  D7                  1977  	SWITCH			Dispatch
1DCA  F3 1D 08 00         1978  ?AG4	FDB	?AG6,$08		Backspace
1DCE  F3 1D 7F 00         1979  	FDB	?AG6,$7F		Delete
1DD2  02 1E 0D 00         1980  	FDB	?AG7,$0D		Return
1DD6  00 00 DA 1D         1981  	FDB	0,?AG5		Default
1DDA                      1982  * Normal character
1DDA  A9 00 00            1983  ?AG5	STB	?temp		Save for later
1DDD  04 00               1984  	LD	,S		Get current position
1DDF  84 04               1985  	CMP	4,S		Are we OK
1DE1  CF                  1986  	UGE			Test for over
1DE2  D5 DF               1987  	SJNZ	?AG3		Ignore
1DE4  94 06               1988  	LDI	6,S		Get pointer
1DE6  05                  1989  	LD	S+		Get size
1DE7  E8                  1990  	ADAI			Adjust pointer
1DE8  E4                  1991  	INC			Advance count
1DE9  DC                  1992  	PUSHA			Resave
1DEA  09 00 00            1993  	LDB	?temp		Get char back
1DED  AA                  1994  	STB	I		Save in buffer
1DEE  D8 9D 1D            1995  	CALL	?putchr		Echo it
1DF1  D3 D0               1996  	SJMP	?AG3		And proceed
1DF3                      1997  * Backspace & delete
1DF3  04 00               1998  ?AG6	LD	,S		Get count
1DF5  D4 CC               1999  	SJZ	?AG3		At zero, ignore
1DF7  E5                  2000  	DEC			Backup
1DF8  A4 00               2001  	ST	,S		Resave
1DFA  90 0C 1E            2002  	LDI	#?AG8		Point to message
1DFD  D8 83 1D            2003  	CALL	?putstr		Output
1E00  D3 C1               2004  	SJMP	?AG3		And proceed
1E02                      2005  * RETURN, terminate entry
1E02  94 06               2006  ?AG7	LDI	6,S		Get buffer pointer
1E04  05                  2007  	LD	S+		Get count
1E05  E8                  2008  	ADAI			Adjust pointer
1E06  E0                  2009  	CLR			Get zero
1E07  AA                  2010  	STB	I		Terminate buffer
1E08  08 0A               2011  	LDB	#$0A		Newline
1E0A  D3 91               2012  	SJMP	?putchr		Output

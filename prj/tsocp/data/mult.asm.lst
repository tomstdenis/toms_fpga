----------------------------------------------------------------------
main                     : 0x00 (0)
mult                     : 0x08 (8)
mult_done                : 0x1D (29)
mult_loop                : 0x10 (16)
multtemp                 : 0x23 (35)
operands                 : 0x24 (36)
product                  : 0x26 (38)
skip_add                 : 0x19 (25)

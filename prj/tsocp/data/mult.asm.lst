ADDR   BYTES          LINE   SOURCE
----------------------------------------------------------------------
00                    1      .ORG 0
00                    2      main:
00     58 21          3          LDi R2,operands     ; R2 = pointer to operands
02     83 08          4          JALR mult           ; call multiply routine
04     54 23          5          LDi R1,product      ; R1 = pointer to where to store product
06     71             6          ST  R0,R1           ; store product
07     F0             7          HALT
                      8      
                      9      ; mult(p) R2 => [operands], product => R0
08                    10     mult:
08     50 20          11         LDi R0,multtemp
0A     7C             12         ST  R3,R0           ; save return address
0B     62             13         LD  R0, R2          ; R0 = Multiplier (A)
0C     98             14         INC R2
0D     66             15         LD  R1, R2          ; R1 = Multiplicand (B)
0E     5C 00          16         LDi R3, 0           ; R3 = Accumulator (Product)
                      17     
10                    18     mult_loop:
                      19         ; Check if Multiplier (R0) is 0
10     40             20         AND R0,R0           ; in reality this is easier for "is zero"
11     81 1B          21         JZ  mult_done       ; Exit loop if R0 is zero
13     F2             22         LSB R0              ; ZF = LSB of R0
14     81 17          23         JZ  skip_add        ; If LSB was 0, skip adding Multiplicand
16     0D             24         ADD R3, R1          ; Accumulator += Multiplicand
17                    25     skip_add:
17     92             26         SHR R0              ; Multiplier >>= 1
18     05             27         ADD R1, R1          ; Multiplicand <<= 1
19     80 10          28         JMP mult_loop
                      29     
1B                    30     mult_done:
1B     A3             31         MOV R0,R3           ; R0 = R3
1C     5C 20          32         LDi R3,multtemp
1E     6F             33         LD  R3,R3           ; restore return address (LDi/LD using same reg is handy for not destroying a pointless reg)
1F     B0             34         RET
20                    35     multtemp:
20     00             36     .DB 0
                      37     
21                    38     operands:
21     07 06          39     .DB 7, 6                ; Inputs: 7, 6. Output placeholder: 0
23                    40     product:
23     00             41     .DB 0                   ; Output placeholder: 0


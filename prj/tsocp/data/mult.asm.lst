ADDR   BYTES          LINE   SOURCE
----------------------------------------------------------------------
00                    1      .ORG 0
00                    2      main:
00     58 22          3          LDi R2,operands     ; R2 = pointer to operands
02     83 08          4          JALR mult           ; call multiply routine
04     54 24          5          LDi R1,product      ; R1 = pointer to where to store product
06     71             6          ST  R0,R1           ; store product
07     F0             7          HALT
                      8      
                      9      ; mult(p) R2 => [operands], product => R0
08                    10     mult:
08     50 21          11         LDi R0,multtemp
0A     7C             12         ST  R3,R0           ; save return address
0B     62             13         LD  R0, R2          ; R0 = Multiplier (A)
0C     98             14         INC R2
0D     66             15         LD  R1, R2          ; R1 = Multiplicand (B)
0E     5C 00          16         LDi R3, 0           ; R3 = Accumulator (Product)
                      17     
10                    18     mult_loop:
                      19         ; Check if Multiplier (R0) is 0
10     40             20         AND R0,R0           ; in reality this is easier for "is zero"
11     81 1B          21         JZ  mult_done       ; Exit loop if R0 is zero
                      22     
                      23         ; Check if LSB of R0 is set using temporary AND logic
                      24         ; (Since we need a copy of R0 to mask bit 0 without losing R0)
                      25         ; In this ISA, we can test odd/even by shifting right and back,
                      26         ; or by keeping a 1 in R2 to test bit 0:
13     F2             27         LSB R0
14     81 17          28         JZ  skip_add        ; If LSB was 0, skip adding Multiplicand
                      29     
16     0D             30         ADD R3, R1          ; Accumulator += Multiplicand
                      31     
17                    32     skip_add:
17     92             33         SHR R0              ; Multiplier >>= 1
                      34         
                      35         ; Shift Multiplicand left: R1 = R1 + R1
18     05             36         ADD R1, R1          ; Multiplicand <<= 1
19     80 10          37         JMP mult_loop
                      38     
1B                    39     mult_done:
1B     20             40         XOR R0,R0
1C     03             41         ADD R0,R3           ; R0 = R3
1D     5C 21          42         LDi R3,multtemp
1F     6F             43         LD  R3,R3           ; restore return address (LDi/LD using same reg is handy for not destroying a pointless reg)
20     B0             44         RET
21                    45     multtemp:
21     00             46     .DB 0
                      47     
22                    48     operands:
22     07 06          49     .DB 7, 6                ; Inputs: 7, 6. Output placeholder: 0
24                    50     product:
24     00             51     .DB 0                   ; Output placeholder: 0


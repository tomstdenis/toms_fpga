ADDR   BYTES          LINE   SOURCE
----------------------------------------------------------------------
                      1      ; -------------------------------------------------------------
                      2      ; Toy ISA Program: Block Memory Fill
                      3      ; Purpose: Fills a block of memory with a pattern. 
                      4      ; Tests: LD, ST, ADD, SUB, JZ, JMP, LDi, and indirect addressing
                      5      ; -------------------------------------------------------------
20                    6      .ORG 32
20                    7      dest_ptr:
20     80             8          .DB 0x80                 ; Target memory block starts at address 80
21                    9      block_count:
21     33             10         .DB 0x33                 ; Fill 0x33 bytes of memory
                      11     
00                    12     .ORG 0
                      13     
00                    14     setup:
                      15         ; Step 1: Initialize our target pointer
00     5C 20          16         LDi  R3, dest_ptr  ; R3 <= dest_ptr
                      17     
                      18         ; Step 2: Initialize our loop counter
02     54 21          19         LDi  R1, block_count   ; R1 <= block_count
04                    20     fill_loop:
                      21         ; Step 3: Write the pattern (using the current count in R1 as the data)
04     77             22         ST   R1, R3        
                      23     
                      24         ; Step 4: Advance pointer (R3++) and decrement counter (R1--)
05     5D 01          25         ADDI R3,1
                      26         ;INC  R3
07     D5             27         DEC  R1
                      28     
08     90 0C          29         JZ done
0A     80 04          30         JMP fill_loop     ; Loop back
                      31     
0C                    32     done:
0C     F0             33         HALT               ; Stop execution. External flag raised.
                      34     

======================================================================
SYMBOL TABLE:
----------------------------------------------------------------------
block_count              : 0x21 (33)
dest_ptr                 : 0x20 (32)
done                     : 0x0C (12)
fill_loop                : 0x04 (4)
setup                    : 0x00 (0)

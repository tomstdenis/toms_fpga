ADDR   BYTES          LINE   SOURCE
----------------------------------------------------------------------
                      1      ; -------------------------------------------------------------
                      2      ; Toy ISA Program: Block Memory Fill
                      3      ; Purpose: Fills a block of memory with a pattern. 
                      4      ; Tests: LD, ST, ADD, SUB, JZ, JMP, LDi, and indirect addressing
                      5      ; -------------------------------------------------------------
00                    6      .ORG 0
00                    7      dest_ptr:
00     80             8          .DB 0x80                 ; Target memory block starts at address 80
01                    9      block_count:
01     33             10         .DB 0x33                 ; Fill 0x33 bytes of memory
                      11     
00                    12     .ORG 0
                      13     
00                    14     setup:
                      15         ; Step 1: Initialize our target pointer
00     5C 00          16         LDi  R3, dest_ptr  ; R3 <= dest_ptr
                      17     
                      18         ; Step 2: Initialize our loop counter
02     54 01          19         LDi  R1, block_count   ; R1 <= block_count
04                    20     fill_loop:
                      21         ; Step 3: Write the pattern (using the current count in R1 as the data)
04     77             22         ST   R1, R3        
                      23     
                      24         ; Step 4: Advance pointer (R3++) and decrement counter (R1--)
05     5D 01          25         ADDI R3,1
07     95             26         DEC  R1
08     82 04          27         JNZ fill_loop     ; Loop back
                      28     
0A                    29     done:
0A     F0             30         HALT               ; Stop execution. External flag raised.
                      31     

======================================================================
SYMBOL TABLE:
----------------------------------------------------------------------
block_count              : 0x01 (1)
dest_ptr                 : 0x00 (0)
done                     : 0x0A (10)
fill_loop                : 0x04 (4)
setup                    : 0x00 (0)
